NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Use a strong random value with at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret

# Auth tuning (optional; sensible defaults are used if unset).
TOKEN_TTL=1d
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_MINUTES=15

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace-with-database-password
DB_NAME=hlqh
# Set to true when connecting to a remote/managed Postgres so the connection uses TLS.
DB_SSL=false

# Keep these disabled in production unless there is a specific operational need.
ENABLE_DEBUG_ROUTES=false
ENABLE_DATABASE_ADMIN=false
